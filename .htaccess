# Activar motor de reescritura
RewriteEngine On

# 1. Eliminar .html de la URL (Redirección externa)
# Si el usuario entra a /pagina.html, lo movemos a /pagina
RewriteCond %{THE_REQUEST} /([^.]+)\.html [NC]
RewriteRule ^ /%1 [NC,L,R=301]

# 2. Mapear URLs limpias a archivos .html (Mapeo interno)
# Si el usuario pide /pagina y existe pagina.html, servimos pagina.html
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [NC,L]

# 3. Mapear URLs limpias a archivos .php (Mapeo interno)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*)$ $1.php [NC,L]

# Forzar HTTPS (Solo en producción/nube)
RewriteCond %{HTTP_HOST} !^localhost$ [NC]
RewriteCond %{HTTP_HOST} !^127\.0\.0\.1$
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
