# Configuración de base de datos para SenApre
# Copiar este archivo a .env y ajustar los valores

# PostgreSQL local (desarrollo)
DATABASE_URL=postgresql://postgres:tu_password@localhost:5432/Senapre

# PostgreSQL producción (Render/Supabase)
# DATABASE_URL=postgresql://usuario:password@host:5432/nombre_db

# Ejemplos de configuración:
# DATABASE_URL=postgresql://postgres:123456@localhost:5432/Senapre
# DATABASE_URL=postgresql://senapre_user:mi_pass@localhost:5432/Senapre

# Nota: Para producción, Render configura automáticamente DATABASE_URL
# Para desarrollo local, ajusta los valores según tu instalación de PostgreSQL
