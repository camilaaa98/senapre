{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/admin/aprendices",
      "regex": "^/admin/aprendices(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/aprendices(?:/)?$"
    },
    {
      "page": "/admin/asistencias",
      "regex": "^/admin/asistencias(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/asistencias(?:/)?$"
    },
    {
      "page": "/admin/dashboard",
      "regex": "^/admin/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/dashboard(?:/)?$"
    },
    {
      "page": "/admin/fichas",
      "regex": "^/admin/fichas(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/fichas(?:/)?$"
    },
    {
      "page": "/admin/programas",
      "regex": "^/admin/programas(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/programas(?:/)?$"
    },
    {
      "page": "/admin/reportes",
      "regex": "^/admin/reportes(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/reportes(?:/)?$"
    },
    {
      "page": "/admin/usuarios",
      "regex": "^/admin/usuarios(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/usuarios(?:/)?$"
    },
    {
      "page": "/instructor/asistencias",
      "regex": "^/instructor/asistencias(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/instructor/asistencias(?:/)?$"
    },
    {
      "page": "/instructor/dashboard",
      "regex": "^/instructor/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/instructor/dashboard(?:/)?$"
    },
    {
      "page": "/instructor/registrar",
      "regex": "^/instructor/registrar(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/instructor/registrar(?:/)?$"
    },
    {
      "page": "/instructor/reportes",
      "regex": "^/instructor/reportes(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/instructor/reportes(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
